  { "id": "2215", "question": "請問下列何者為固體製劑，可注射在皮下，緩慢溶解以長時間釋放藥物？", "options": { "A": "植入製劑(Implants)", "B": "緩釋製劑(repository drugs)", "C": "酏劑(Elixirs)", "D": "糊劑(Pastes)" }, "answer": "A" },
  { "id": "2216", "question": "請問下列何者為治療梨形鞭毛蟲(giardiasis)的首選用藥", "options": { "A": "Metronidazole(Flagyl®)", "B": "Spinosad(Comfortis®)", "C": "Penicillin", "D": "Tepoxalin(Zubrin)" }, "answer": "A" },
  { "id": "2217", "question": "請問下列何者屬於SOAP病歷記錄的主觀資訊(subjective information)？", "options": { "A": "獸醫師診斷該犬罹患脂漏性皮膚炎", "B": "患犬吃了兩杯量的乾狗糧", "C": "動物醫事助理數了一下，患犬身上總共有有七處咬傷", "D": "飼主說患犬似乎比平時還要疲累" }, "answer": "D" },
  { "id": "2218", "question": "請問下列何者屬於或會造成人畜共通傳染病？1肺結核、2白點病、3立百病毒、4傳染性喉頭氣管炎", "options": { "A": "1、2", "B": "1、3", "C": "1、4", "D": "1" }, "answer": "B" },
  { "id": "2219", "question": "請問下列何種給藥方式，最適合維持動物抗生素的血液藥物濃度？", "options": { "A": "靜脈一次性推注給藥", "B": "間歇性靜脈注射給藥", "C": "連續靜脈輸注給藥", "D": "皮下植入給藥" }, "answer": "C" },
  { "id": "2220", "question": "請問下列何種裝置，可讓接受全非消化道給與營養(TPN)的病患，能夠再額外給與藥物？", "options": { "A": "滴液室(Dripchamber)(", "B": "層流式無菌操作台(Laminar flow hood)", "C": "輸液幫浦(Fluid pump)", "D": "雙腔導管(Double-lumen catheter)" }, "answer": "D" },
