<script>
    const questions = [
  { "id": "1", "question": "＿＿＿反應了藥袋標示、藥品分裝、以及核對藥品數量所費時間的成本？", "options": { "A": "加成費(Markup)", "B": "架儲費(shelflife)", "C": "基本處方費(minimum prescription fee)", "D": "調劑費(dispensing fee)" }, "answer": "D" },
  { "id": "2", "question": "＿＿＿是一種防水、可熱封的防塵罩", "options": { "A": "滅菌前包裝(presterilization wrap)", "B": "滅菌後包裝(poststerilization wrap)", "C": "布巾包裝(drape wrap)", "D": "滅菌袋(sterilization pouch)" }, "answer": "B" },
  { "id": "3", "question": "＿＿＿前面被擋住＿＿＿該如何與病患互動？", "options": { "A": "只需完成工作，不需互動", "B": "提供友好的服務和支持", "C": "避免與病患交流", "D": "只在必要時與病患溝通" }, "answer": "B" },
  { "id": "4", "question": "「天然」一詞在寵物食品中指的是什麼？", "options": { "A": "含有防腐劑的食品", "B": "含有化學添加劑", "C": "經過高溫處理的食品", "D": "未添加任何合成或人工成分" }, "answer": "D" },
  { "id": "5", "question": "「有機」一詞在寵物食品中代表什麼？", "options": { "A": "只使用冷凍成分", "B": "所有成分都來自植物", "C": "不含任何添加劑", "D": "用於生長作物或飼養牲畜的方法" }, "answer": "D" },
  { "id": "6", "question": "「我覺得她有某種感染，因為她一直在抓癢」，飼主這樣告訴動物醫事助理。飼主接著說：他一直有皮脂漏的問題，而且我注意到她最近更常在地毯上拖著屁走。請問以下所列的行為，何者是最為適當的？", "options": { "A": "動物醫事助理在病患的病史記錄皮脂漏", "B": "動物醫事助將病患的診斷記為肛門腺阻塞", "C": "動物醫事助提出問題詢問以確定飼主是否了解皮脂漏的意思", "D": "將主訴記錄為皮脂" }, "answer": "C" },
  { "id": "7", "question": "「哦，她是個小壞蛋！」飼主有點小抱怨地跟動物醫事助理說她的紅貴賓，「我回家看到家裡地上一堆咬爛的衛生紙就罵了她，結果你知道嗎？她看了我一眼，就在廚房尿尿生我的氣！」。請問飼主這樣解讀大的行為，我們將之稱為稱為？", "options": { "A": "社會化", "B": "擬人化", "C": "減敏作用", "D": "反制約作用" }, "answer": "B" },
  { "id": "8", "question": "「轉介」的目的為何？", "options": { "A": "推卸責任", "B": "增加營收", "C": "協助動物接受更專業治療", "D": "避免醫療糾紛" }, "answer": "C" },
  { "id": "9", "question": "○○動物醫院A藥的平均需求量為40(顆/天)，安全存量設定為400顆，採購前置時間為3天，若採再訂購點(re-order Point)之藥品訂購策略，請問A藥的再訂購點應設定在多少顆？", "options": { "A": "400", "B": "520", "C": "640", "D": "720" }, "answer": "B" },
  { "id": "10", "question": "○○動物醫院在候診區貨架固定放著4瓶精品燕麥洗毛精販售，每瓶售價新台幣600元，去年該產品售出新台幣24000元，請問洗毛精的庫存周轉率為？", "options": { "A": "40", "B": "100", "C": "10", "D": "20" }, "answer": "C" },
  { "id": "11", "question": "100磅(lb)的狗，換算成公制，請問是幾公斤(kg)？", "options": { "A": "220", "B": "100", "C": "45.5", "D": "45.4" }, "answer": "D" },
  { "id": "12", "question": "13歲的貓，慢性腎病3期，出現明顯的腎性蛋白尿，BCS3/9。該貓同時患有糖尿病，通過胰島素調節，仍高於正常值，以下哪種飲食方案是目前比較適合該患貓的推薦？", "options": { "A": "成貓糖尿病處方糧", "B": "成貓腎臟處方糧", "C": "先使用腎臟處方糧病情穩定後，更換糖尿病處方糧調節血糖", "D": "先使用糖尿病處方糧幫助調節血糖，後更換腎臟處方糧" }, "answer": "B" },
  { "id": "13", "question": "1公斤(kg)比1公克(g)", "options": { "A": "大10000倍", "B": "大100倍", "C": "大10倍", "D": "大1000倍" }, "answer": "D" },
  { "id": "14", "question": "2歲已絕育公犬，慢性嘔吐伴有皮膚發紅搔癢，醫生懷疑存在食物過敏，準備進行排查，以下描述正確的是？", "options": { "A": "可以送檢進行過敏原篩查，排除結果中所有導致過敏的食物", "B": "主人選擇了一款網紅無穀糧作為低敏飲食，可用於食物排除試驗", "C": "低過敏處方糧使用大豆水解蛋白，降低蛋白分子量，減少致敏", "D": "餵食羽毛水解蛋白配方，進行至少8周的食物排除試驗，並嚴格禁止狗狗吃到其他食物" }, "answer": "D" },
  { "id": "15", "question": "2歲貓就診，發現已嘔吐腹瀉10天，精神狀況正常，食慾佳。主人希望先不做過多檢查，此時", "options": { "A": "首選腸道處方飼料", "B": "首選低過敏處方飼料", "C": "首選康復期濕糧", "D": "首選高纖易消化處方飼料" }, "answer": "A" },
  { "id": "16", "question": "3kg的貓(假定維持量180ml/天)、10%脫水，預計在24小時補完脫水，預計輸液量為何？", "options": { "A": "5ml/hr", "B": "10ml/hr", "C": "20ml/hr", "D": "30ml/hr" }, "answer": "C" },
  { "id": "17", "question": "3歲巴哥，體重10kg，BCS(體態評分)8/9，以下對其飲食建議不合理的是？", "options": { "A": "其理想體重為7kg，建議該犬減重", "B": "需要低能量密度的飲食", "C": "飲食中需要較高的蛋白含量", "D": "飲食中無需碳水化合物，可避免體重升高" }, "answer": "D" },
  { "id": "18", "question": "3歲患犬，慢性嘔吐，每週2-3次，持續三個月以上，胃鏡檢查發現了大量螺旋桿菌，確診為細菌性胃炎，暫無其他疾病症狀提示，可推薦的食物是？", "options": { "A": "犬腸胃低脂處方糧", "B": "犬腸胃道處方糧", "C": "犬低過敏性處方糧", "D": "犬腸胃道高纖處方糧" }, "answer": "B" },
  { "id": "19", "question": "3歲患貓，BCS3，慢性腹瀉2年有餘，嘗試多種治療手段均無好轉。試用貓胃腸道處方飼料，使用1月後症狀依舊，此時：", "options": { "A": "建議使用低過敏處方飼料", "B": "建議繼續使用胃腸道處方飼料", "C": "建議使用康復期處方濕糧", "D": "建議使用成貓配方飼料" }, "answer": "A" },
  { "id": "20", "question": "3歲患貓就診，主訴家裡新養了一隻貓，患貓出現緊迫反應，食慾稍有下降，頻繁去貓砂盆，排尿時發出叫聲，膀胱穿刺採尿進行尿檢沒有發現細菌，但發現了少量鳥糞石結晶，經診斷為非阻塞性FIC(特發性膀胱炎)，以下對該患貓的飼養管理不合適的是", "options": { "A": "幫助患貓增加日常飲水", "B": "緩解緊迫因素，可以使用費洛蒙作為輔助", "C": "停止餵食乾糧，長期餵食零食罐頭或水煮雞肉", "D": "只需更換為情緒舒緩處方糧" }, "answer": "C" },
  { "id": "21", "question": "3歲絕育母犬，疫苗完整，無驅蟲史，餵食商品化寵物糧，無換糧史，但不限零食。持續性軟便一個月左右，有時一天會拉3-4次，平日啃咬、舔舐、抓撓頻率和時長均有所增加，以下哪種食物可作為優先推薦進行嘗試？", "options": { "A": "成犬腸胃道處方糧", "B": "成犬腸胃道低脂處方糧", "C": "成犬皮膚處方糧", "D": "成犬皮膚低過敏處方糧" }, "answer": "D" },
  { "id": "22", "question": "4歲已絕育公貓，搬家後出現排尿問題，醫生診斷為自發性膀胱炎，尿檢中發現草酸鈣結晶。以下關於該貓營養管理的描述錯誤的是？", "options": { "A": "需要針對該貓壓力問題舒緩情緒", "B": "需要幫助患貓增加飲水，可以建議使用濕糧", "C": "成貓泌尿道處方糧可以酸化尿液導致草酸鈣結晶增加，不推薦使用", "D": "建議推薦成貓泌尿道+舒緩緊張專用配方" }, "answer": "C" },
  { "id": "23", "question": "4歲患犬，症狀為油膩樣腹瀉(脂肪痢)，噁心，但食欲旺盛，醫生診斷為胰外分泌不足(EPI)，未出現繼發慢性胰腺炎，以下對該患犬飲食的推薦要點錯誤的是？", "options": { "A": "餵食低脂肪食物", "B": "易消化、高能量密度食物", "C": "高纖維食物", "D": "飲食需要配合添加額外的胰酶" }, "answer": "C" },
  { "id": "24", "question": "5歲黃金獵犬，先天性髖關節發育不良，已經出現跛行，主人拒絕手術決定採用保守治療，醫生推薦該換將飲食更換為犬關節處方糧，可以為患犬帶來的好處不包含以下哪點？", "options": { "A": "補充大量的鈣", "B": "避免能量攝入過多，控制體重，減少關節負擔", "C": "添加omega-3脂肪酸有助於抗發炎", "D": "添加硫酸軟骨素、氨基葡萄糖有助於保護關節軟骨" }, "answer": "A" },
  { "id": "25", "question": "5歲雌性美短，8kg，主訴隔壁近一周裝修聲音較大，貓咪食慾下降，基本不吃東西，就診時已出現黃疸，醫生診斷為肝脂肪沉積，對該患貓的治療下列推薦錯誤的是？", "options": { "A": "儘快恢復飲食", "B": "建議使用成貓肝臟處方糧", "C": "建議使用犬貓康復期處方濕糧", "D": "必要時可使用管飼" }, "answer": "B" },
  { "id": "26", "question": "6歲美國短毛家貓，已絕育，體重7kg，體況評分8分，非常可愛粘人。主人帶到醫院體檢，發現血糖比較高，醫生診斷為糖尿病，建議飼主進行藥物加飲食管理。對於這個病例你的營養管理方案是什麼？", "options": { "A": "吃皇家糖尿病處方飼料就對了", "B": "貓糖尿病大部分和肥胖相關，這只貓已經處於肥胖，需要先使用體重控制處方飼料", "C": "醫生建議經常核查血糖曲線：先使用糖尿病處方飼料，再根據貓的情況更換成體重控制處方飼料", "D": "配合胰島素做貓糖尿病飼料的血糖曲線，等血糖控制穩定直接換成相同熱量的體重控制處方飼料" }, "answer": "C" },
  { "id": "27", "question": "6歲鬥牛犬，體態評分8/9，走路都喘，主人經常嘗試減肥但是無法抗拒牠渴望食物的眼神。減肥是一個艱難的過程，除了適度增加運動量，還要嚴格控制食物攝入。為了減少動物的饑餓感，皇家減肥處方糧如何控制動物乞食？", "options": { "A": "大量脂肪延緩胃排空", "B": "增加碳水化合物不讓動物感到饑餓", "C": "減少纖維含量，提高飽腹感", "D": "增加顆粒體積" }, "answer": "D" },
  { "id": "28", "question": "6歲患犬長期大腸性下痢，糞便呈糊狀，有粘液，血便，裡急後重，嘗試胃腸道處方飼料後症狀仍然持續，此時可以首選嘗試", "options": { "A": "犬低過敏處方飼料", "B": "犬高纖易消化處方飼料", "C": "犬低脂易消化處方飼料", "D": "犬胃腸道處方濕糧" }, "answer": "B" },
  { "id": "29", "question": "7歲患貓，主訴最近排便減少，2-3天排便一次，糞便較硬，評分約5/9分，影像學檢查，腸腔內有大量糞便，但未出現巨結腸。去年也偶爾發生便秘，通過浣腸緩解。此次浣腸後，為了防止復發，可以為其推薦的飲食為？", "options": { "A": "成貓腸胃道處方糧", "B": "成貓腸胃道處方濕糧", "C": "成貓腸胃道低卡路里處方糧", "D": "成貓腸胃道高纖處方糧" }, "answer": "D" },
  { "id": "30", "question": "7歲暹羅貓，雌性已絕育，BCS9/9。飼主觀察存在嘔吐腹瀉症狀，就診確診為胰腺炎。經治療後，病情穩定，無任何臨床症狀，但血脂爆表。目前需要選擇下階段營養管理方案，首選推薦的飲食為？", "options": { "A": "貓過敏控制處方飼料", "B": "貓體重控制處方飼料", "C": "貓腸胃道處方飼料", "D": "貓腸胃高纖易消化處方飼料" }, "answer": "B" },
  { "id": "31", "question": "9歲查理斯王小獵犬，患有黏液性的二尖瓣膜疾病，已發展為C期，複查腎臟功能時發現肌酐SDMA均有升高，無蛋白尿，醫生判斷繼發慢性腎病，發展至2期，以下最適合該患犬的糧食推薦為？", "options": { "A": "成犬早期腎病處方糧", "B": "成犬腎病處方糧", "C": "成犬腎臟處方濕糧", "D": "成犬心臟病處方濕糧" }, "answer": "D" },
  { "id": "32", "question": "Acepromazine maleate屬於？", "options": { "A": "鴉片類(opioid)", "B": "巴比妥酸鹽類(Barbiturates)", "C": "phenothiazine類鎮靜劑", "D": "benzodiazepine類鎮靜劑" }, "answer": "C" },
  { "id": "33", "question": "ACE抑制劑(ACE Inhibitors)的主要副作用是什麼？", "options": { "A": "心律過快", "B": "低血壓和高血鉀", "C": "呼吸困難", "D": "脫水和耳毒性" }, "answer": "B" },
  { "id": "34", "question": "ACTH刺激試驗，一般來說用以診斷何者疾病？", "options": { "A": "庫興氏症/艾迪森氏症", "B": "甲狀腺功能亢進", "C": "甲狀腺功能低下", "D": "糖尿病" }, "answer": "A" },
  { "id": "35", "question": "Amoxicillin在犬的劑量為30mg/kg/day，分為一天兩次給予，而此藥的口服懸浮液，濃度為125mg/5mL，那麼20kg的患犬，每次需服用mL？", "options": { "A": "9", "B": "12", "C": "18", "D": "24" }, "answer": "B" },
  { "id": "36", "question": "Amoxicillin的描述何者正確？", "options": { "A": "藥品通用名", "B": "品牌藥名", "C": "發明者姓名", "D": "以上皆非" }, "answer": "A" },
  { "id": "37", "question": "Amoxicillin與ampicillin都是am為首的藥物，描述何者正確？", "options": { "A": "相同成份", "B": "不同成分", "C": "可能相同也可能不同", "D": "以上皆非" }, "answer": "B" },
  { "id": "38", "question": "A經營一動物醫院，某日B帶著愛貓C至動物醫院就診，A向B表示C需留院觀察3天，然3天後B未出現，B亦未接電話，至第9日時，B終於接了A的電話，A表示如B今天再不來帶貓回去，將依動物保護法向動物保護主管機關檢舉B棄養C，B聽了之後心生恐懼，於是在當天下午將C接回去並付清所有款項，請針對上述情境，選出適當的答案。", "options": { "A": "A無法向動物保護主管機關依動物保護法第5條第3項規定，檢舉這6天B棄養C。", "B": "A可向動物保護主管機關檢舉B未提供C適當醫療。", "C": "B可向管理獸醫單位主管機關，依獸醫師法第11條規定檢舉A這6天拒絕替C醫療。", "D": "B可向動物保護主管機關檢舉A，未依動物保護法第22條第1項後段規定，取得貓隻寄養營業執照，經營貓隻寄養。" }, "answer": "A" },
  { "id": "39", "question": "Bradycardia這個專有名詞，指的是心率異常變慢，請問下列何者是bradycardia的相反詞？", "options": { "A": "Supracardia", "B": "Tachycardia", "C": "Megacardia", "D": "Hypercardia" }, "answer": "B" },
  { "id": "40", "question": "Capnometer測量的是什麼？", "options": { "A": "血壓", "B": "血液中的二氧化碳", "C": "氧飽和度", "D": "組織灌注" }, "answer": "B" },
  { "id": "41", "question": "Carprofen，或稱6-chloro-a-methyl-9H-carbazole-2-aceticacid，是一種非類固醇抗炎症藥(NSAID)，通常以Rimadyl®的名稱銷售，用於治療犬關節疼痛的問題。請問下列何者為其專利藥名(proprietary name)？", "options": { "A": "6-Chloro-a-methyl-9H-carbazole-2-aceticacid", "B": "NSAID", "C": "Rimadyl®", "D": "Carprofen" }, "answer": "C" },
  { "id": "42", "question": "Carprofen的建議劑量是2.2mg/kg，一天服用兩次，請問35kg的患犬，每天需服用＿＿＿mg", "options": { "A": "22", "B": "35", "C": "75", "D": "154" }, "answer": "D" },
