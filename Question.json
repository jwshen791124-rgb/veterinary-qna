  { "id": "2023", "question": "電話接待時的第一步是什麼？", "options": { "A": "確認飼主的名字", "B": "主動自我介紹並問候", "C": "記錄飼主的問題", "D": "直接提供診療時間" }, "answer": "B" },
  { "id": "2024", "question": "電漿滅菌過程是將何種化學物質轉換成電漿態？", "options": { "A": "酒精", "B": "環氧乙烷", "C": "過氧化氫", "D": "戊二醛" }, "answer": "C" },
  { "id": "2025", "question": "預防犬貓泌尿道結石發生和復發的最重要的因素是哪個？", "options": { "A": "是否使用泌尿道處方糧", "B": "是否大量飲水，保證充足水分攝入", "C": "是否使用泌尿道處方濕糧", "D": "定期帶寵物醫院體檢" }, "answer": "B" },
  { "id": "2026", "question": "預約資訊包含哪些要素？", "options": { "A": "顧客的喜好", "B": "顧客預約時間、聯絡資訊及寵物需求", "C": "僅限於診所的營業時間", "D": "員工的午茶時間" }, "answer": "B" },
  { "id": "2027", "question": "飼主A用牽繩牽獒犬B出外至公園散步，A未替B掛嘴套，正巧C外出慢跑迎面朝A及B跑來，B大聲吠叫嚇到了C，C跌倒之後便與A大發生爭執，B嚇得躲到A後面瑟瑟發抖，請針對上述情境，選出最適當的答案。", "options": { "A": "C可向主管機關投訴，表示B吠叫一定是有狂犬病，依動物傳染病防治條例檢罩A未替B提供狂犬病疫苗施打。", "B": "A可向動物保護主管機關檢躍C嘯到B，哭訴B嚇得瑟瑟發抖，請主管機關依動物保護法第6條規定，C不得照擾、虐待動物，請主管機關務必給予C制裁。", "C": "C可依動物保護法第20條第2項規定，向動物保護主管機關檢躍A带B出入公共場所或公眾得出入之場所時，未替B掛上嘴套。", "D": "C可依動物保護法第20條第2項規定，向動物保護主管機關檢單並請動物保護主管機關依行政程序法協助。向A提出民事賠償告訴。" }, "answer": "C" },
  { "id": "2028", "question": "飼主主訴患貓無法直線行走，而且還摔倒好幾次，請問獸醫師會懷疑是以下哪一個結構發生問題？", "options": { "A": "鎚骨(malleus)", "B": "前庭(vestibule)", "C": "角膜(cornea)", "D": "耳蝸(cochlea)" }, "answer": "B" },
  { "id": "2029", "question": "飼主因動物醫院服務所產生的欠費總額，在會計科目上稱為＿＿＿？", "options": { "A": "應付帳款", "B": "發票金額", "C": "信用額度", "D": "未付帳款" }, "answer": "A" },
  { "id": "2030", "question": "飼主在獸醫師陪同下前來病房接患犬出院，當獸醫師要將患犬移交給飼主時，患犬因看到飼主過於興奮，獸醫師一時手沒抓緊牽繩，患犬就衝向飼主，撞倒剛好路過的病房清潔助理，導致其跌倒，造成尾椎骨折，而正在現場的動物醫事助理目睹一切，也來不及阻止事件發生，請問誰應該對病房助理尾椎骨折負最大責任？", "options": { "A": "飼主", "B": "獸醫師", "C": "病房清潔助理", "D": "動物醫事助理" }, "answer": "B" },
  { "id": "2031", "question": "飼主早上將動物帶至動物醫院進行絕育手術，該動物手術後會留院一天，隔日再回家，所以飼主準備了一張毯子，希望動物留院期間能感到舒適，請問動物醫事助理在下列哪個表單註記飼主留下一張毯子最為恰當？", "options": { "A": "住院登記單", "B": "知情同意書", "C": "估價單", "D": "病史記錄" }, "answer": "A" },
  { "id": "2032", "question": "飼主走進診所時，應如何招待飼主？", "options": { "A": "主動打招呼", "B": "帶領掛號", "C": "寒暄", "D": "揮揮手" }, "answer": "A" },
  { "id": "2033", "question": "飼主取消預約時，接待人員應該？", "options": { "A": "表示感謝並詢問是否重新安排時間", "B": "不理會，直接掛斷電話", "C": "告知飼主不能取消", "D": "提醒飼主造成診所不便" }, "answer": "A" },
  { "id": "2034", "question": "飼主抱怨他的新養幼犬一直啃咬桌腳，請問身為動物醫事助理的您，以下建議，何者最為適當？", "options": { "A": "「建議您應該多帶牠到外面走走」", "B": "「這是正常現象，您沒有辦法阻止」", "C": "「如果您發現牠正在啃咬時，可以用低沉且嚴厲的聲音對他說「不行！」」", "D": "「當他這樣做的時候，給牠一些可以咬的東西代替，比如一根棍子」" }, "answer": "D" },
  { "id": "2035", "question": "飼主抱怨他們的貓有攻擊性時，通常表示貓對哪些對象具有攻擊性", "options": { "A": "犬", "B": "其他貓", "C": "烏", "D": "陌生人" }, "answer": "B" },
  { "id": "2036", "question": "飼主為增加貓使用貓抓板磨爪的興趣，請問下列處置方式，何者效果可能最差？", "options": { "A": "將貓抓板或抓柱置於貓喜歡抓的物品附近", "B": "將貓抓板或抓柱放在貓砂盆附近", "C": "使用灑有貓薄荷的貓抓板或抓柱", "D": "將貓抓板或抓柱放在可能會觸發行為的位置附近" }, "answer": "B" },
  { "id": "2037", "question": "飼主根據獸醫師的處方，每天給愛犬服用1錠16mg的fluoxetine(Reconcile)以治療分離焦慮症。不過，一個月過去了，飼主仍未見到愛犬的行為有任何改變。因此，獸醫師便將劑量加倍提高到32mg。請問獸醫師為何覺得16mg不管用，要將劑量提高到32mg？", "options": { "A": "給藥頻率不足", "B": "16mg的劑量不足以產生預計療效", "C": "16mg的劑量已達中毒濃度", "D": "患犬服用藥物的時間不夠長，所以還無法產生藥效" }, "answer": "B" },
  { "id": "2038", "question": "飼主將生病動物委任獸醫師診治，形成民法上的契約關係，獸醫師與動物醫院工作人員負有盡善良管理人之注意義務，本於獸醫學知識而為適當的醫療照護，那麼請問飼主的義務是什麼？", "options": { "A": "尊重動物醫院工作人員", "B": "支付醫療服務所產生的費用", "C": "相信獸醫師的專業判斷", "D": "聽從獸醫師的醫囑與衛教指導" }, "answer": "B" },
  { "id": "2039", "question": "飼主帶了一隻剛吃了整盒內外寄生蟲預防藥的米格魯犬，請問針對這隻患犬的治療方式，下列何者是獸醫師最有可能優先使用的藥物？", "options": { "A": "催吐劑", "B": "利尿劑", "C": "支氣管擴張劑", "D": "緩瀉劑" }, "answer": "A" },
  { "id": "2040", "question": "飼主帶寵物到動物醫院看診時，動物醫事助理必須領導飼主先做什麼？", "options": { "A": "給動物藥吃", "B": "掛號或調出病歷資料", "C": "把動物關起來", "D": "帶去做檢查" }, "answer": "B" },
  { "id": "2041", "question": "飼主得到最正確的資訊來源應為", "options": { "A": "網友", "B": "臨床醫療從業人員", "C": "店家老闆間", "D": "自稱有經驗的飼主" }, "answer": "B" },
  { "id": "2042", "question": "飼主探病時，建議病房晚上不應關燈，這樣動物住院時就不會再黑暗中感到害怕，請問下列回答，何者最為適當？", "options": { "A": "燈光會使得動物太熱", "B": "動物在黑暗中的視力比人類好，所以牠們不會害怕", "C": "病房有明顯的晝夜變化，對於動物生理時鐘會有正面影響", "D": "動物在開燈的狀態下，很難入眠" }, "answer": "C" },
  { "id": "2043", "question": "飼主透過電話預約愛犬疫苗接種，請問該飼主對於這家動物醫院的第一印象會是？", "options": { "A": "動物醫院的氣味", "B": "獸醫師的舉止表現", "C": "動物醫院整潔度", "D": "電話應對" }, "answer": "D" },
  { "id": "2044", "question": "飼主對於其管領之動物，下列何者為非？", "options": { "A": "可以用汽、機車牽引寵物", "B": "提供適當、乾淨且無害之食物及二十四小時充足、乾淨之飲水", "C": "以繩或鍊圈束寵物者，其繩或鍊應長於寵物身形且足供寵物充分伸展、活動，使用安全、舒適、透氣且保持適當鬆緊度之項圈，並應適時提供充分之戶外活動時間。", "D": "除絕育外，不得對寵物施以非必要或不具醫療目的之手術。" }, "answer": "A" },
  { "id": "2045", "question": "飼主對於其管領之動物，下列何者為非？", "options": { "A": "提供法定動物傳染病之必要防治", "B": "有發生危害之虞時，應將寵物移置安全處，並給予逃生之機會", "C": "只要有對流孔洞供其呼吸，可以長時間將寵物留置密閉空間內", "D": "提供安全、乾淨、通風、排水、適當及適量之遮蔽、照明與溫度之生活環境" }, "answer": "C" },
  { "id": "2046", "question": "飼主說明老年犬站起來困難及失禁問題時，動物醫事助理意識到飼主正在考慮安樂死，請問這屬於積極聆聽的哪一個步驟？", "options": { "A": "接收訊息", "B": "處理訊息", "C": "回覆訊息", "D": "結束對話" }, "answer": "B" },
  { "id": "2047", "question": "飼主擔心貓長途搭車旅行會有焦慮症，獸醫師推薦使用Banophen(diphenhydramine)。該藥劑型為25mg錠劑。此貓重量5.7kg，建議劑量是每8至12小時服用4.4mg/kg。客戶每次應該給予錠？", "options": { "A": "0.5", "B": "1", "C": "1.5", "D": "2" }, "answer": "B" },
  { "id": "2048", "question": "飼主應如何保護其所飼養的動物？", "options": { "A": "防止其傷害他人的生命", "B": "防止其傷害他人的身體", "C": "防止其傷害他人的自由", "D": "以上皆是" }, "answer": "D" },
  { "id": "2049", "question": "飼主應該如何對待所領養的動物？", "options": { "A": "不得以機車牽引動物", "B": "使用安全舒適的牽繩牽引", "C": "不長時間留置在密閉之空間", "D": "以上皆是" }, "answer": "D" },
  { "id": "2050", "question": "飼主應該如何對待所領養的動物？", "options": { "A": "發現有危害之處時就移開動物", "B": "給予犬貓節育", "C": "不棄養", "D": "以上皆是" }, "answer": "D" },
  { "id": "2051", "question": "飼養兩生寵物時，哪些水質的參數需要定期檢查", "options": { "A": "鹽度", "B": "硬度", "C": "鹼度", "D": "以上皆是" }, "answer": "D" },
  { "id": "2052", "question": "飼養爬蟲時使用的加熱工具，以下何者錯誤", "options": { "A": "加溫石很適合拿來做為加溫工具", "B": "缸底加溫器建議只用一半的面積", "C": "加溫的熱源建議設置在爬蟲到不了的位置", "D": "加溫設備使用不當會有🗎傷風險" }, "answer": "A" },
  { "id": "2053", "question": "鼠兔嚙齒類的門牙(切齒)特徵是？", "options": { "A": "兩側有鋸齒狀邊緣", "B": "持續生長並不斷磨損", "C": "無法生長", "D": "只在某些物種中生長" }, "answer": "B" },
  { "id": "2054", "question": "實驗動物醫學中，物種分隔飼養的主要目的是·", "options": { "A": "降低照護人力成本", "B": "避免跨物種疾病傳播", "C": "提升實驗數據準確性", "D": "符合動物福利法規" }, "answer": "B" },
  { "id": "2055", "question": "對有空腔的器械進行高壓滅菌所應注意之事項，以下所列，何者最為正確", "options": { "A": "高壓滅菌前確保完全乾燥", "B": "在空腔內填充器械潤滑劑(instrumentmilk)", "C": "在高壓滅菌之前，空腔先用水沖洗", "D": "帶有空腔的器械不能高壓滅" }, "answer": "A" },
  { "id": "2056", "question": "對於一隻3歲胰腺炎患貓，以下適合的飲食建議是？", "options": { "A": "嚴格控制脂肪攝入", "B": "可以提供極高蛋白含量的飲食", "C": "可以推薦成貓腸道處方糧(適中能量)", "D": "可以推薦體重控制處方糧" }, "answer": "C" },
  { "id": "2057", "question": "對於一隻因晚期心臟病導致食慾廢絕、體重持續下降並出現「心因性惡病質」的犬隻，下列哪一項飲食管理目標應為當務之急？", "options": { "A": "嚴格控制鈉的攝取量。", "B": "確保攝取足夠的熱量與高生物價值的蛋白質。", "C": "轉換成高纖維配方以改善腸胃功能。", "D": "增加Omega-3脂肪酸的補充以對抗發炎。" }, "answer": "B" },
  { "id": "2058", "question": "對於大多數大動物的靜脈注射，應該使用哪個靜脈？", "options": { "A": "乳靜脈", "B": "頸靜脈", "C": "耳靜脈", "D": "蹄靜脈" }, "answer": "B" },
  { "id": "2059", "question": "對於不熟悉的動物，最初的保護方法應該是？", "options": { "A": "使用強力器具", "B": "立即給予鎮靜劑", "C": "採取輕柔且漸進的方法", "D": "讓動物自由移動" }, "answer": "C" },
  { "id": "2060", "question": "對於心衰竭的犬，臨床營養上控制鈉離子滯留程度的方式不包括什麼？", "options": { "A": "限制鈉離子攝取", "B": "維持能量和蛋白質攝取", "C": "補充牛磺酸", "D": "補充維生素B群" }, "answer": "C" },
  { "id": "2061", "question": "對於欠費分期的飼主，應該多久寄送帳單通知繳費較為適當？", "options": { "A": "每天", "B": "每週", "C": "每月", "D": "每季" }, "answer": "C" },
  { "id": "2062", "question": "對於水牛，推薦的安樂死方法是什麼？", "options": { "A": "穿透式固定鉚釘", "B": "槍擊", "C": "巴比妥類藥物", "D": "鎮靜劑" }, "answer": "B" },
  { "id": "2063", "question": "對於牛隻的安樂死，使用氯化鉀的靜脈注射時，必須確保動物的狀態是什麼？", "options": { "A": "清醒", "B": "昏迷", "C": "無意識", "D": "激動" }, "answer": "C" },
  { "id": "2064", "question": "對於甲狀腺功能亢進的貓，臨床營養上支持增加之能量需求的方式不包括什麼？", "options": { "A": "增加纖維攝取", "B": "增加能量攝取", "C": "增加維生素和礦物質攝取", "D": "增加蛋白質攝取" }, "answer": "A" },
  { "id": "2065", "question": "對於甲狀腺功能亢進的貓，臨床營養上需要考量的目標是什麼？", "options": { "A": "每日3-6次少量多餐餵食", "B": "限制鈣、磷的攝取", "C": "支持增加的能量需求", "D": "維持攝取所有除了能量外的養分" }, "answer": "C" },
  { "id": "2066", "question": "對於任何安樂死程序，應在何種情況下諮詢獸醫？", "options": { "A": "有任何不確定性或不適感時", "B": "在所有情況下", "C": "只在初次使用時", "D": "只在動物受傷時" }, "answer": "A" },
  { "id": "2067", "question": "對於有肝臟疾病的犬貓，臨床營養上需要考量的目標不包含什麼？", "options": { "A": "減少蛋白質新陳代謝", "B": "維持肝臟肝醣", "C": "避免氨中毒", "D": "減少食物脂肪量" }, "answer": "D" },
  { "id": "2068", "question": "對於有毒性或攻擊性強的蛇，利用何種工具抓取較為安全", "options": { "A": "蛇鋏", "B": "蛇鉤", "C": "止血鉗", "D": "黏鼠板" }, "answer": "B" },
