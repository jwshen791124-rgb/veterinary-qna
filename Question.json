  { "id": "2239", "question": "請問下列敘述，何者代表動物醫事助理已知道已將趾爪修剪到適當的長度？", "options": { "A": "趾爪出血", "B": "病患反抗", "C": "趾爪中心看起來是白色的", "D": "趾爪中心看起來呈肉質光澤的外觀" }, "answer": "D" },
  { "id": "2240", "question": "請問下列液體製劑，何者濃度最高？", "options": { "A": "55μg/mL", "B": "15mg/mL", "C": "20μg/μL", "D": "50mg/dL" }, "answer": "C" },
