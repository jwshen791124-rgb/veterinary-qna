  { "id": "1304", "question": "保持牛舍的通風良好的主要目的是？", "options": { "A": "降低乳腺炎發生", "B": "預防呼吸道疾病", "C": "減少腐蹄病發生", "D": "預防消化道疾病" }, "answer": "B" },
  { "id": "1305", "question": "南美栗鼠主食為牧草，全口共＿＿＿牙齒，均會持續生長，健康的門齒顏色應為？", "options": { "A": "28顆/橘色", "B": "16顆/透明白色", "C": "20顆/橘色", "D": "20顆/透明白色" }, "answer": "C" },
  { "id": "1306", "question": "南美栗鼠每個毛孔會長出50-100根左右的毛，身上披覆極厚的毛皮保護身體，於飼養環境所需溫度建議為攝氏？", "options": { "A": "18-22度", "B": "25-29度", "C": "27-32度", "D": "32-35度" }, "answer": "A" },
  { "id": "1307", "question": "南美栗鼠活動時評估距離及空間的特殊器官結構為？", "options": { "A": "鼻周毛髮", "B": "鼻子", "C": "鬍鬚", "D": "嘴巴" }, "answer": "C" },
  { "id": "1308", "question": "南美栗鼠原生地為乾燥地區，皮脂腺會分泌名為羊毛脂的油脂，避免身體過於乾燥人為飼養環境去除多餘油脂所需進行的活動為砂浴，請問建議的材質為？", "options": { "A": "松木砂", "B": "紙砂", "C": "礫砂", "D": "火山灰砂" }, "answer": "D" },
  { "id": "1309", "question": "品種寵物是具有共同的鮮明外觀特徵(例如：毛的長短與質地、頭和耳朵的形狀、尾巴形態、骨骼形態等)，並且可以將品種特徵穩定遺傳給下一代。請問目前FCI認可的犬的品種數量約為：", "options": { "A": "250", "B": "350", "C": "500", "D": "600" }, "answer": "B" },
  { "id": "1310", "question": "客戶最多可以獲得多少天的管制藥物供應？", "options": { "A": "90天", "B": "30天", "C": "120天", "D": "60天" }, "answer": "B" },
  { "id": "1311", "question": "建議多久在牧場進行一次行走評分？", "options": { "A": "每次擠奶後", "B": "每月定期檢查", "C": "每季一次", "D": "每年一次" }, "answer": "B" },
  { "id": "1312", "question": "很多養貓人士認為生食餵養的貓長得快，肌肉更發達等等，但不可忽視的是，不少權威機構都不建議生食，是因為", "options": { "A": "生食有潛在的寄生蟲或細菌污染的風險", "B": "生食製作通常需要花費主人大量的時間、精力和耐心，一般上班族無法做到", "C": "目前生食的配方多數不夠成熟，實際做出來的生食配方通常營養不均衡", "D": "以上皆是" }, "answer": "D" },
  { "id": "1313", "question": "後天性行為指的是什麼？", "options": { "A": "與生活相關的行為", "B": "透過經驗或學習獲得的行為", "C": "與環境無關的行為", "D": "無法改變的行為" }, "answer": "B" },
  { "id": "1314", "question": "怎樣的寵物適合任食？", "options": { "A": "大部分的寵物都適合", "B": "患有糖尿病的貓", "C": "會出門散步的狗", "D": "能自行維持體態不肥胖的貓" }, "answer": "D" },
  { "id": "1315", "question": "怎樣的寵物適合任食？", "options": { "A": "大部分的寵物都適合", "B": "過重的動物", "C": "幼犬", "D": "泌乳中的雌性" }, "answer": "D" },
  { "id": "1316", "question": "施用外用藥物時，為什麼需要戴手套？", "options": { "A": "防止化學物質傷害皮膚", "B": "保持藥物的有效性", "C": "保護藥物", "D": "不需要戴手套" }, "answer": "A" },
  { "id": "1317", "question": "施用外用藥物時，應該如何處理傷口或擦傷？", "options": { "A": "用冷水沖洗", "B": "直接塗抹藥物", "C": "用溫水和外科清洗劑浸泡", "D": "不需要處理" }, "answer": "C" },
  { "id": "1318", "question": "施用外用藥物時，應該如何塗抹藥物？", "options": { "A": "隨意塗抹", "B": "直接倒在傷口上", "C": "以圓形運動從中心向外塗抹", "D": "用手指塗抹" }, "answer": "C" },
  { "id": "1319", "question": "施用眼藥時，應該如何打開動物的眼睛？", "options": { "A": "用棉球壓住眼睛", "B": "用手指和拇指拉開上下眼瞼", "C": "不需要打開眼睛", "D": "用手捏住鼻子" }, "answer": "B" },
  { "id": "1320", "question": "施用眼藥時，應該如何處理眼睛的分泌物？", "options": { "A": "用手擦拭", "B": "用棉球擦拭", "C": "用水沖洗", "D": "不需要處理" }, "answer": "B" },
  { "id": "1321", "question": "是非題：雪貂得到心絲蟲的機率很低，並不需要每個月做心絲蟲預防？", "options": { "A": "是", "B": "否", "C": "此題為是非題，勿選此選項", "D": "此題為是非題，勿選此選項" }, "answer": "B" },
  { "id": "1322", "question": "某一患犬準備進行髖關節關節鏡手術時，以下所列之方式，何者最適合用於刷洗該病患腿部的周圍？", "options": { "A": "將病患保持站立姿勢進行保定", "B": "將病患置於俯臥姿", "C": "將腿懸掛在點滴架上", "D": "將腿懸掛在檢查檯的側" }, "answer": "C" },
  { "id": "1323", "question": "某天，有位飼主正向某動物醫事助理講述他看到自己年邁的巴吉度犬每每從地上站起來，都要經過一番掙扎才能蹣跚而起十分困難，而且當大小便失禁，保持清潔也是很大的問題。動物醫事助理非常專心地聆聽，並在談話過程中，意識到飼主正在考慮讓動物實施安樂術。請問在如下所列之積極聆聽(active listening)的四步驟中，這位動物醫事助理是在哪一個步驟聽出飼主的意思？", "options": { "A": "接收訊息", "B": "處理訊息", "C": "回覆訊息", "D": "結束對話" }, "answer": "B" },
  { "id": "1324", "question": "某犬因「落下巴」(dropped jaw)就診，飼主還說該犬也有無法咀嚼的問題。請問聽了這些陳述後，獸醫師最有可能會懷疑哪一條神經發生神經病變", "options": { "A": "顏面神經(facial nerve)", "B": "三叉神經(trigeminal nerve)", "C": "嗅神經(olfactory nerve)", "D": "外旋神經(abducent nerve)" }, "answer": "B" },
  { "id": "1325", "question": "某犬有癲癇發作的問題，其體重為30kg，獸醫師開立phenobarbital治療，劑量為1mg/kg。每天早晩各服用1次，倘若該院phenobarbital劑型為15mg/錠，請問該犬每天需服用幾錠？", "options": { "A": "1", "B": "2", "C": "4", "D": "8" }, "answer": "C" },
  { "id": "1326", "question": "某丙打電話給動物醫院，詢問除蚤外用滴劑的使用方法，但是某丙很難聽懂接電話的櫃檯人員說什麼，因為櫃檯人員很忙，也說得很急。請問櫃檯人員的電話聲音出了什麼問題？", "options": { "A": "音調", "B": "音量", "C": "音速", "D": "音質" }, "answer": "C" },
  { "id": "1327", "question": "某丙年邁的愛貓咪咪，一直不吃牠以前喜歡吃的罐頭，故尋求建議，看看有無方式增加其食慾。請問下列建議，何者最為適當？", "options": { "A": "加入冷水", "B": "用微波爐加熱", "C": "換品牌", "D": "與乾糧混合" }, "answer": "B" },
  { "id": "1328", "question": "某丙有兩隻犬與一隻貓，全部都是在○○動物醫院看診。該院使用POMR的病歷記錄系統，請問某丙的動物，其病歷記錄在該院會放在幾個文件夾裡？", "options": { "A": "1個", "B": "2個", "C": "3個", "D": "答案取決於某丙的動物多久就診一次" }, "answer": "A" },
  { "id": "1329", "question": "某丙為其3歲齡的愛貓投保寵物險，每年支付新台幣7，111元，在寵物醫療費用保險部分，每一保險事故理賠失70%，並有額度與次數險制，保險期間內累積最高賠償限額為新台幣56，000元，請問某丙需自行負擔的30%，稱之為＿＿＿？", "options": { "A": "差別費率", "B": "自負額", "C": "部分負擔", "D": "保險金額" }, "answer": "B" },
  { "id": "1330", "question": "某丙帶著她的鬥牛犬來動物醫院看眼精的問題，因為候診人數多，所以某丙等了好了一陣子，但是有個比某丙晚來，帶狗來擠肛門腺的飼主卻比她早進診間，某丙因此略感不滿，請問為何院方為何讓齊江門腺的飼主先進診間？", "options": { "A": "因為擠肛門線比較簡單，所以獸醫師想要先解決", "B": "擠肛門腺是緊急狀況，所以需優先處理", "C": "帶狗擠肛門腺的飼主其實早就預約，只是遅到了", "D": "肛門線可交由動物醫事助理執行，讓獸醫師專心看診" }, "answer": "D" },
  { "id": "1331", "question": "某甲正在為一位接受全非消化道给與營養(TPN)的病患準備混合溶液。講問以下所列之行為，何者表示某甲需要更多訓練？", "options": { "A": "某甲最後才加入維生素", "B": "某甲嚴格遵守無菌操作", "C": "某甲加入葡萄糖與電解質前先加入脂肪", "D": "某甲使用自動混合幫浦" }, "answer": "C" },
  { "id": "1332", "question": "某甲正在照顧一位術後接受管灌營養補充的病患，這種營養補充不是該病患原本的正常飲食。病患目前已達到完整的熱量攝入。請下所列之行為，何者代表某甲還要再接受更多關於管灌營養的教育訓練？", "options": { "A": "某甲在每次餵食後，會再灌入10毫升的水", "B": "某甲只花1至2天的時間，就把餵食管灌食方式轉換為正常經口進食方式", "C": "某甲根據產品標籤上的資訊計算食物的卡路里密度", "D": "某甲在餵食管仍在的情況下提供新鮮食物" }, "answer": "B" },
  { "id": "1333", "question": "某甲注意到digoxin的口服液體製劑為酏劑(elixir)，故猜測digoxin應該是", "options": { "A": "無錠劑製劑", "B": "不溶於酒精", "C": "溶於水", "D": "不溶於水" }, "answer": "D" },
  { "id": "1334", "question": "某甲的主要工作是維持病房籠與住院動物的清潔，供應新鮮衛生的食物與飲水，並注意住院動物有無行為變化，請問某甲最有可能是這家動物醫院的＿＿＿？", "options": { "A": "動物醫事助理", "B": "櫃檯掛號人員", "C": "行政人員", "D": "病房清潔助理" }, "answer": "D" },
  { "id": "1335", "question": "某甲是一位經驗豐富的現職動物醫事助理，某日出門上班時巧遇鄰居某丙正在遛他的愛犬Lucky，她發現Lucky左前肢的指爪腫脹，於是提醒某丙，Lucky可能是感染或其他問題，建議某丙應該帶Lucky去動物醫院看看，由獸醫師診治左前肢指爪腫脹的問題，根據前文所述，請問下列關於某甲行為的敘述，何者最為正確？", "options": { "A": "某甲不具獸醫師資格，卻對Lucky的問題進行診斷，因此違反獸醫師法", "B": "某甲為現職動物醫事助理，只要有任職動物醫院的獸醫師事後背書，向鄰居提供任何動物醫學方面的建議，並不違反獸醫師法", "C": "某甲未取得獸醫師授權與某丙同意，逕行向某丙提供建議，違反獸醫師法", "D": "某甲提醒某丙Lucky可能有感染或其他問題，建議至動物醫院就診的行為，並無危害lucky健康之慮，也不具治療目的與用藥行為，僅為動物利益而為的建議，故無違反獸醫師法" }, "answer": "D" },
  { "id": "1336", "question": "某甲為某動物醫院的動物醫事助理，輪值住院部時，她發現有一位飼主某丙，非常擔心其8歲齡吉娃娃(呼名：娃娃)在住院期間的狀況，每次探病總是要等到探視時間結束才肯離開，請問某甲要怎麼做，才能減輕某丙在娃娃住院期間的心理壓力？", "options": { "A": "給予娃娃止痛處理", "B": "定期向某丙傳送娃娃住院期間的照片", "C": "經常向某丙回報娃娃住院期間的進展", "D": "提供安寧療護(Hospice Care)的資料給某丙" }, "answer": "C" },
  { "id": "1337", "question": "某羊場有80隻的綿羊，每隻大約重90kg，獸醫師告知養殖戶每5公斤體重給予1mL的Cydectin(moxidectin)驅蟲劑，這種驅蟲劑為桶裝液體，每桶為1L，請問該養殖戶需要幾桶？", "options": { "A": "3.6", "B": "1.44", "C": "2", "D": "1.35" }, "answer": "B" },
  { "id": "1338", "question": "某位動物醫事助理與主管因排班問題出現爭論：「妳老是把我排在星期六上午，妳明明知道我兒子通常那天都有活動」，請問這位動物醫事助理的話語，哪個部分會激怒對方？", "options": { "A": "「妳老是？？」", "B": "「？？通常？？」", "C": "「？？妳明明知道？？」", "D": "句子都是以「妳」為開頭" }, "answer": "A" },
  { "id": "1339", "question": "某位動物醫事助理聽完飼主的陳述後，歸納了動物就診的原因：「所以，您想檢查一下牠的牙齦，還有肚子上的疹子，請問我說得對嗎？」，請問這位動物醫事助理使用哪一種主動聆聽的技巧？", "options": { "A": "營造合適環境", "B": "沉思", "C": "分析", "D": "有意義的回饋" }, "answer": "D" },
  { "id": "1340", "question": "某位飼主的狗出現食慾不振和無精打采已經好幾天了。獸醫師看到血液檢查結果後，要求進行腹部放射攝影檢查，包括右側位照、左側位照和腹背照。放射影像顯示出hepatomegaly。請問患犬的肝臟發生什麼異常？", "options": { "A": "萎縮", "B": "癌性", "C": "腫大", "D": "位置錯誤" }, "answer": "C" },
  { "id": "1341", "question": "某位飼主的動物在手術中出現併發症而不幸死亡，悲痛萬分的飼主聲稱獸醫師從未告知動物可能因手術而死亡，揚言要上法院提告獸醫師醫療疏失。請問面對訴訟，院方手上有哪份文件可證明飼主事前知曉手術可能出現的併發症與動物死亡的風險？", "options": { "A": "知情同意書", "B": "估價單", "C": "病歷記錄", "D": "飼主與病患的基本資料表" }, "answer": "A" },
  { "id": "1342", "question": "某位飼主的愛犬因手術過程中出現併發症而死亡。兩天後，飼主在公司的會議中，突然開始抽泣，請問這位飼主正在經歷喪慟的何種階段？", "options": { "A": "否認(Denial)", "B": "悲傷(Sorrow)", "C": "內疚(Guilt)", "D": "憤怒(Anger)" }, "answer": "B" },
  { "id": "1343", "question": "某些品種的貓咪容易患上心臟病，需要特別引起飼主的注意，定期體檢。下列何種不包含在內？", "options": { "A": "英國短毛貓", "B": "賓士貓", "C": "布偶貓", "D": "緬因貓" }, "answer": "B" },
  { "id": "1344", "question": "某些鳥種的鼻孔周圍會有一個鼓起的構造，又被稱為", "options": { "A": "鳥喙", "B": "鼻毛", "C": "蠟膜", "D": "鼻鏡" }, "answer": "C" },
  { "id": "1345", "question": "某動物醫事助理正準備為一隻貴賓犬清理耳朵。請問下列何者是第一步應該執行的動作？", "options": { "A": "取得培養檢體或樣本", "B": "給患犬戴上口罩", "C": "拔除或修剪耳毛", "D": "檢查鼓膜" }, "answer": "D" },
  { "id": "1346", "question": "某動物醫事助理負責照護一窩幼犬的營養，請問以下所列之行為，何者最不正確？", "options": { "A": "動物醫事助理餵食幼犬牛奶", "B": "動物醫事助理每天幫幼犬量兩次體重", "C": "動物醫事助理讓體重過輕的幼犬每天3到4次在沒有競爭的情況下吸吮母乳", "D": "動物醫事助理使用針筒餵食幼犬，直到牠們開始茁壯成長" }, "answer": "A" },
  { "id": "1347", "question": "某動物醫事助理想要向獸醫師說明，有一隻雪貂的皮膚問題是從其腹部開始，然後蔓延至其下巴與鼻部，請問皮疹(rash)往哪個方向擴散？", "options": { "A": "Rostral", "B": "Dorsal", "C": "Caudal", "D": "Ventral" }, "answer": "A" },
